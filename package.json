{
    "name": "@coinstats/coinstats-mcp",
    "version": "2.0.0",
    "description": "MCP server for CoinStats API integration — stdio CLI + Cloudflare Worker",
    "main": "dist/index.js",
    "bin": {
        "coinstats-mcp": "dist/index.js"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "coinstats",
        "crypto",
        "api",
        "mcp",
        "model context protocol",
        "ai",
        "mcp server",
        "coinstats mcp",
        "cloudflare workers"
    ],
    "author": "CoinStats",
    "license": "MIT",
    "scripts": {
        "build": "npm i && npm run build:types && npm run build:js && shx chmod +x dist/index.js",
        "build:js": "tsc",
        "build:types": "tsc --emitDeclarationOnly",
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "tail": "wrangler tail"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "zod": "^3.24.2",
        "zod-to-json-schema": "^3.24.5"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20251001.0",
        "@types/node": "^22.13.13",
        "shx": "^0.4.0",
        "typescript": "^5.8.2",
        "wrangler": "^4.32.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CoinStatsHQ/coinstats-mcp.git"
    },
    "bugs": {
        "url": "https://github.com/CoinStatsHQ/coinstats-mcp/issues"
    },
    "homepage": "https://github.com/CoinStatsHQ/coinstats-mcp#readme"
}
